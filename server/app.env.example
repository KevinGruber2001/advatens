# Local development config — copy to app.env and fill in.
# Postgres is published on 127.0.0.1:5433 by the root docker-compose.yml.
DB_HOST=localhost
DB_PORT=5433
DB_DATABASE=advatens
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_SCHEMA=public

MQTT_BROKER_URL=tcp://localhost:1883

CLERK_SECRET_KEY=

# Comma-separated origins allowed by CORS (defaults to common local dev URLs)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ChirpStack Configuration
CHIRPSTACK_API_URL=localhost:8080
# Option 1: Provide an API token directly (production)
CHIRPSTACK_API_TOKEN=
# Option 2: Leave token empty, auto-login with credentials (defaults to admin/admin)
CHIRPSTACK_ADMIN_EMAIL=
CHIRPSTACK_ADMIN_PASSWORD=
