# Shared config for docker-compose and local development
# Copy this to .env and fill in your values

# =============================================================================
# DATABASE
# =============================================================================
DB_DATABASE=advatens
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_SCHEMA=public
# Host port Postgres is published on (loopback only). 5433 avoids colliding
# with a natively installed Postgres on 5432.
DB_PORT=5433

# =============================================================================
# CHIRPSTACK
# =============================================================================
# Secret used by ChirpStack to sign login/API tokens. Generate a real one for
# production: openssl rand -base64 32
CHIRPSTACK_API_SECRET=
# Credentials the Go server uses to log into ChirpStack (change in production)
CHIRPSTACK_ADMIN_EMAIL=admin
CHIRPSTACK_ADMIN_PASSWORD=admin

# =============================================================================
# CORS
# =============================================================================
# Comma-separated origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# CLERK AUTHENTICATION
# =============================================================================
CLERK_SECRET_KEY=
VITE_CLERK_PUBLISHABLE_KEY=

# =============================================================================
# FRONTEND
# =============================================================================
VITE_API_BASE_URL=http://localhost:8888
